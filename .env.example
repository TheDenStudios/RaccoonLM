# RaccoonLM v2 — Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
# RACCOONLM_PORT=5555
# RACCOONLM_DEBUG=false

# Ollama backend
# RACCOONLM_OLLAMA_HOST=http://localhost:11434
# RACCOONLM_DEFAULT_MODEL=qwen3:4b

# Plugins
# RACCOONLM_INTERNET_PLUGIN=true

# Database
# RACCOONLM_DB_PATH=raccoonlm.db
