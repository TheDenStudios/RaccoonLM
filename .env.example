# RaccoonLM v2 — Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
# RACCOONLM_PORT=5555
# RACCOONLM_DEBUG=false

# llama.cpp direct provider
# RACCOONLM_LLAMA_CPP_HOST=http://localhost:8080
# RACCOONLM_LLAMA_CPP_COMMAND=llama-server
# RACCOONLM_LLAMA_CPP_MODEL_DIRS=
# RACCOONLM_LLAMA_CPP_GPU_LAYERS=999

# Plugins
# RACCOONLM_INTERNET_PLUGIN=true

# Database
# RACCOONLM_DB_PATH=raccoonlm.db
